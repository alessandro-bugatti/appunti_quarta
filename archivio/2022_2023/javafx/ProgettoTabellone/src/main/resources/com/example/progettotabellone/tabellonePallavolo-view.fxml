<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.progettotabellone.TabellonePallavoloController">
   <left>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblCasa" text="0">
               <font>
                  <Font size="72.0" />
               </font>
            </Label>
            <Button mnemonicParsing="false" text="Casa" />
         </children>
      </VBox>
   </left>
   <right>
      <VBox prefHeight="65.0" prefWidth="211.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblOspiti" text="0">
               <font>
                  <Font size="72.0" />
               </font>
            </Label>
            <Button mnemonicParsing="false" onAction="#onBtnOspitiClick" text="Ospiti" />
         </children>
      </VBox>
   </right>
</BorderPane>
