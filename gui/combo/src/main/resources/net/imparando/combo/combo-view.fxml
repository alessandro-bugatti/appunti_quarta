<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="103.0" prefWidth="473.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.imparando.combo.ComboController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <HBox fx:id="hboxComuniStati" prefHeight="100.0" prefWidth="200.0">
      <children>
         <CheckBox fx:id="chkEstero" mnemonicParsing="false" onAction="#onEsteroSelected" text="Estero">
            <HBox.margin>
               <Insets right="20.0" />
            </HBox.margin></CheckBox>
         <ChoiceBox fx:id="choComuni" prefWidth="150.0" />
         <ComboBox fx:id="cmbStati" editable="true" prefWidth="150.0" />
      </children>
   </HBox>

    <Label fx:id="welcomeText" />
    <Button onAction="#onHelloButtonClick" text="Hello!" />
</VBox>
